# led-blinker.resc — Run LED Blinker on Nucleo F446RE

using sysbus
$name?="Nucleo-F446RE"

mach create $name
machine LoadPlatformDescription $repl

macro reset
"""
    sysbus LoadELF $bin
    start
    log "HW reset button emulated: system-wide reset (CPU + peripherals) triggered"
"""

showAnalyzer sysbus.usart2
sysbus LoadELF $bin

start
